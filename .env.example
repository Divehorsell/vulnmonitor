# VulnMonitor 环境变量配置
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=vulnmonitor
APP_VERSION=0.1.0
DEBUG=false

# 数据库配置
DB_PATH=data/vulnmonitor.db

# 采集配置
CRAWL_INTERVAL=15
CRAWL_TIMEOUT=30
CRAWL_MAX_RETRIES=3
CRAWL_CONCURRENCY=20

# 去重配置
DEDUP_TTL_DAYS=60

# 推送配置
PUSH_ENABLED=true
PUSH_SCORE_THRESHOLD=50.0

# Telegram 推送
TG_BOT_TOKEN=
TG_CHAT_ID=

# 钉钉推送
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 企业微信推送
WECOM_WEBHOOK=

# 飞书推送
FEISHU_WEBHOOK=
FEISHU_SECRET=

# 邮件推送
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# GitHub 配置
GITHUB_TOKEN=

# Web 界面配置
WEB_HOST=127.0.0.1
WEB_PORT=8080

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=data/logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# 安全配置
ENCRYPTION_KEY=
